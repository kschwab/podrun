{
    "image": "ssd-docker-dev-virtual.artifactorygslb.micron.com/plato/future:40.2",
    "workspaceMount": "source=${localWorkspaceFolder},target=/podrun,type=bind",
    "workspaceFolder": "/podrun",
    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/podrun/.claude/config"
    },
    "customizations": {
        "podrun": {
            "hostOverlay": true,
            "dotFilesOverlay": true,
            "login": true,
            "autoAttach": true,
            "podmanRemote": true,
            "exports": ["~/.aws:.claude/config/.aws"],
            "localStoreIgnore": true,
            "fuseOverlayfs": true,
            "shell": "bash"
        }
    }
}
